# Backend environment variables
SECRET_KEY=replace-with-a-strong-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: move local SQLite file outside this git repo to avoid runtime file diffs
# DATABASE_URL=sqlite:///C:/Users/your-user/AppData/Local/CarValueAI/car_value_ai.db

# Optional: external LLM enhancement for /chat (fallback works without this)
# LLM_API_KEY=your-provider-key
# GEMINI_API_KEY=your-gemini-key (alias for Gemini)
# GOOGLE_API_KEY=your-google-key (alias for Gemini)
# LLM_MODEL=gemini-1.5-flash
# LLM_TIMEOUT_SECONDS=12
# GEMINI_MAX_RETRIES=2

# Optional: override Gemini endpoint URL
# If empty, default Google endpoint is used.
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent
